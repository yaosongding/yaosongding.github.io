---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { t } from "../../i18n/utils";
import type { Locale } from "../../i18n/translations";

const locale = Astro.currentLocale as Locale;
const path = Astro.url.pathname;
---

<BaseLayout locale={locale} title={t(locale, "contact.title")} path={path}>
  <h1>{t(locale, "contact.title")}</h1>

  <div class="contact-list">
    <div class="contact-item">
      <span class="label">{t(locale, "contact.email")}</span>
      <span class="value">yaosongding AT qq.com</span>
    </div>

    <div class="contact-item">
      <span class="label">{t(locale, "contact.github")}</span>
      <a href="https://github.com/yaosongding" class="value" target="_blank" rel="noopener noreferrer">
        github.com/yaosongding
      </a>
    </div>

    <div class="contact-item">
      <span class="label">{t(locale, "contact.linkedin")}</span>
      <a href="https://www.linkedin.com/in/yaosongding4396/" class="value" target="_blank" rel="noopener noreferrer">
        linkedin.com/in/yaosongding4396
      </a>
    </div>
  </div>
</BaseLayout>

<style>
  h1 {
    margin-bottom: 2rem;
  }

  .contact-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .label {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .value {
    font-size: 1.05rem;
  }
</style>
