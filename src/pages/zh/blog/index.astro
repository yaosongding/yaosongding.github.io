---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { t } from "../../../i18n/utils";
import type { Locale } from "../../../i18n/translations";

const locale = Astro.currentLocale as Locale;
const path = Astro.url.pathname;

const allPosts = await getCollection("blog", ({ id }) => id.startsWith(`${locale}/`));
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout locale={locale} title={t(locale, "blog.title")} path={path}>
  <h1>{t(locale, "blog.title")}</h1>

  {
    posts.length === 0 ? (
      <p class="empty">{t(locale, "blog.noPosts")}</p>
    ) : (
      <div class="post-list">
        {posts.map((post) => {
          const slug = post.id.replace(`${locale}/`, "").replace(/\.md$/, "");
          const href = `/${locale}/blog/${slug}`;
          return (
            <a href={href} class="post-card">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString(locale === "zh" ? "zh-CN" : "en-US", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </time>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
            </a>
          );
        })}
      </div>
    )
  }
</BaseLayout>

<style>
  h1 { margin-bottom: 2rem; }
  .empty { color: var(--color-text-muted); }
  .post-list { display: flex; flex-direction: column; gap: 0.75rem; }
  .post-card {
    display: block;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
    transition: border-color 0.15s ease;
  }
  .post-card:last-child { border-bottom: none; }
  .post-card:hover { border-color: var(--color-accent); color: var(--color-text); }
  .post-card time {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }
  .post-card h3 { margin: 0.25rem 0 0.35rem; font-size: 1.1rem; }
  .post-card p { color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 0; }
</style>
