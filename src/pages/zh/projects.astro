---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { t } from "../../i18n/utils";
import type { Locale } from "../../i18n/translations";

const locale = Astro.currentLocale as Locale;
const path = Astro.url.pathname;

interface Project {
  name: string;
  description: Record<Locale, string>;
  url?: string;
  tags: string[];
}

const projects: Project[] = [];
---

<BaseLayout locale={locale} title={t(locale, "projects.title")} path={path}>
  <h1>{t(locale, "projects.title")}</h1>

  {
    projects.length === 0 ? (
      <p class="empty">{t(locale, "projects.noProjects")}</p>
    ) : (
      <div class="project-list">
        {projects.map((p) => (
          <a href={p.url ?? "#"} class="project-card">
            <h3>{p.name}</h3>
            <p>{p.description[locale]}</p>
            <div class="tags">
              {p.tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
          </a>
        ))}
      </div>
    )
  }
</BaseLayout>

<style>
  h1 {
    margin-bottom: 2rem;
  }

  .empty {
    color: var(--color-text-muted);
  }

  .project-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .project-card {
    display: block;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.25rem;
    color: var(--color-text);
    transition: border-color 0.15s ease;
  }

  .project-card:hover {
    border-color: var(--color-accent);
    color: var(--color-text);
  }

  .project-card h3 {
    margin-bottom: 0.35rem;
  }

  .project-card p {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 0.75rem;
  }

  .tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.15rem 0.5rem;
    background: var(--color-accent-dim);
    color: var(--color-accent);
    border-radius: 3px;
    font-family: var(--font-mono);
  }
</style>
